^SAMPLE = GSM4074527
!Sample_title = Myceliphothora thermophila wt_Glucose 2 h R1
!Sample_geo_accession = GSM4074527
!Sample_status = Public on Sep 12 2019
!Sample_submission_date = Sep 11 2019
!Sample_last_update_date = Sep 12 2019
!Sample_type = SRA
!Sample_channel_count = 1
!Sample_source_name_ch1 = Mycelium sample
!Sample_organism_ch1 = Thermothelomyces thermophilus
!Sample_taxid_ch1 = 78579
!Sample_characteristics_ch1 = strain: wild type
!Sample_characteristics_ch1 = sampling time: Glucose 2 h
!Sample_growth_protocol_ch1 = All Myceliophthora thermophila strains described in this study were grown on Malt Extract Agar (MEA) plates at 37 °C for 7 days to obtain conidia. For growth phenotypic profiling, the WT and ΔMtxyr1 strain were grown on minimal medium agar plates (pH set to 6.0) containing AspA+N (70 mM NaNO3, 7 mM KCl, 11 mM KH2PO4), 2 mM MgSO4, trace elements (174 µM EDTA, 76 µM ZnSO4·7H2O, 178 µM H3BO3, 25 µM MnSO4·H2O, 18 µM FeSO4.7H2O, 7.1 µM CoCl2·6H2O, 6.4 µM CuSO4·5H2O and 6.2 µM Na2MoO4·2H2O), 1.6% agar-agar (Merck Company, Darmstadt, Germany), 10 mM of uridine (if necessary) and 25 mM of D-glucose, D-xylose, L-arabinose or cellobiose or 1% of birchwood xylan, wheat arabinoxylan, Avicel or cellulose. All sugar substrates were purchased from Sigma-Aldrich (St. Louis, MO, USA), except for cellobiose (Acros Organics, Belgium), wheat arabinoxylan (Megazyme, Wicklow, Ireland) and Avicel (Fluka Chemicals, Buchs, Switzerland). Strains were inoculated with 2 µl containing 500 spores and grown for 5 days at 37 °C. For RNA-seq analysis, the WT and ΔMtxyr1 strain were pre-grown in complete medium (pH 6.0) containing AspA+NH4, 2 mM MgSO4, trace elements, 0.1% casamino acids, 4 μg/L biotin and 2% D-fructose. Strains were inoculated with 1·106 spores per mL and incubated at 37 °C at 200 rpm in a rotary shaker. After 36h of incubation, aliquots of the mycelium wereas transferred to shake flasks with minimal medium and as a carbon source 1% of D-glucose, D-xylose, L-arabinose or wheat arabinoxylan, respectively. Minimal medium (pH 6.0) contained AspA+NH4, 2 mM MgSO4, trace elements, 0.1% casamino acids, 4 μg/L biotin and was buffered by anwith extra addition of 70 mM KH2PO4. Mycelial samples were harvested after 2 h of incubation in all monosaccharide cultures and after 2 and 8h of incubation in case of the wheat arabinoxylan culture. The mycelial samples were dried between tissue paper and directly frozen in liquid nitrogen for RNA extraction.
!Sample_molecule_ch1 = total RNA
!Sample_extract_protocol_ch1 = Total RNA was extracted from mycelium ground in a Tissue Lyser II (Qiagen, Venlo, the Netherlands) using TRIzol reagent (Invitrogen, Breda, the Netherlands) and purified with NucleoSpin® RNA II Clean-up kit (Macherey-Nagel) with rDNase treatment. The RNA quantity and quality was checked with a RNA6000 Nano Assay using the Agilent 2100 Bioanalyser (Agilent Technologies, Santa Clara, CA, USA). RNA samples were single-end sequenced at BGI Tech Solutions Co., Ltd. (Hong Kong, China) using Illumina HiSeqTM 2000 platform (http://illumina.com).
!Sample_extract_protocol_ch1 = RNA libraries were prepared for sequencing using standard Illumina protocols.
!Sample_description = Myceliphothora thermophila wild type grown on Glucose for 2 h
!Sample_data_processing = Illumina Casava1.7 software used for basecalling.
!Sample_data_processing = Sequenced reads were trimmed for adaptor sequence, and removed for low-quality sequence, then mapped to Myceliophthora thermophila v2.0 ( https://mycocosm.jgi.doe.gov/Spoth2/Spoth2.home.html) genome using BWA/Bowtie2 (Langmead B et al., Genome Biology, 2009) .
!Sample_data_processing = “Fragments per kilobase of exon model per million mapped reads” (RPKM) was calculated using RSEM tool (Li B & Dewey CN, BMC bioinformatics, 2011).
!Sample_data_processing = Genome_build: Myceliophthora thermophila v2.0 ( https://mycocosm.jgi.doe.gov/Spoth2/Spoth2.home.html)
!Sample_data_processing = Supplementary_files_format_and_content: tab-delimited text files include RPKM values for each Sample
!Sample_platform_id = GPL27455
!Sample_contact_name = Ronald,,de Vries
!Sample_contact_email = fungalphysiology@gmail.com
!Sample_contact_phone = + 31 (0)30 2122600
!Sample_contact_department = fungal physiology
