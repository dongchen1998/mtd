^SAMPLE = GSM675519
!Sample_title = Myceliophthora_thermophila_Barley_34C_rep1
!Sample_geo_accession = GSM675519
!Sample_status = Public on Aug 08 2011
!Sample_submission_date = Feb 15 2011
!Sample_last_update_date = May 15 2019
!Sample_type = SRA
!Sample_channel_count = 1
!Sample_source_name_ch1 = Mycelium
!Sample_organism_ch1 = Thermothelomyces thermophilus
!Sample_taxid_ch1 = 78579
!Sample_characteristics_ch1 = carbon source: Barley straw
!Sample_characteristics_ch1 = growth temperature: 34C
!Sample_growth_protocol_ch1 = Spores of each filamentous fungus were inoculated at a final concentration of 10^6/mL into 10x Trametes Defined Medium containing 2% carbon source.  Liquid cultures were grown with shaking at 150 rpm at 34C or 45C.  Mycelia were harvested by filtering through Miracloth (Calbiochem) and ground in liquid nitrogen.  RNA was extracted with Trizol (Invitrogen, Carlsbad CA, USA) according to the manufacturer's protocol.
!Sample_molecule_ch1 = polyA RNA
!Sample_extract_protocol_ch1 = Libraries were prepared according to Illumina's instructions accompanying the mRNA-Seq Sample Prep Kit
!Sample_extract_protocol_ch1 = gel-based size selection
!Sample_data_processing = Short reads from C. globosum were aligned to the assembly of the Chaetomium globosum CBS 148.51 genome from the Broad Institute using TopHat v1.0.13. Reads from M. thermophila were aligned with BowTie v0.12.7 to the Sporotrichum thermophile genome assembly v2.0 from the DOE Joint Genome Institute, augmented with splice junction sequences. Introns were first located by mapping the pooled reads to the genomic sequence with BLAT; reads that aligned with >95% identity and coverage, but with gaps, were examined for the presence of plausible introns in the gaps. Splice junction sequences were constructed by concatenating 35 bases of sequence from the two flanks of the introns thus identified. Read alignments to the splice junction sequences were translated into gapped alignments to the genome. Reads that mapped equally well to more than one location were randomly assigned to one of the locations with probability proportional to the local depth of coverage by uniquely-mapped reads. Reads from T. terrestris were mapped to the Thielavia terrestris genome v2.0 from JGI.
!Sample_platform_id = GPL15335
!Sample_contact_name = Ian,,Reid
!Sample_contact_email = ian.reid@concordia.ca
!Sample_contact_laboratory = Centre for Structural and Functional Genomics
!Sample_contact_department = Biology
!Sample_contact_institute = Concordia University
!Sample_contact_address = 7141 Sherbrooke West
!Sample_contact_city = Montreal
!Sample_contact_state = QC
!Sample_contact_zip/postal_code = H9S 4Y5
!Sample_contact_country = Canada
!Sample_instrument_model = Illumina Genome Analyzer II
!Sample_library_selection = cDNA
!Sample_library_source = transcriptomic
!Sample_library_strategy = RNA-Seq
!Sample_relation = SRA: https://www.ncbi.nlm.nih.gov/sra?term=SRX043463
!Sample_relation = BioSample: https://www.ncbi.nlm.nih.gov/biosample/SAMN00215951
